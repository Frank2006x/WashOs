    {
      "name": "Bookings - Processing",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Processing list returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Processing list has bookings array', function () {",
              "  pm.expect(Array.isArray(json.bookings)).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{staff_access_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/bookings/processing?limit=20&offset=0",
          "host": ["{{baseUrl}}"],
          "path": ["api", "bookings", "processing"],
          "query": [
            { "key": "limit", "value": "20" },
            { "key": "offset", "value": "0" }
          ]
        }
      }
    },
