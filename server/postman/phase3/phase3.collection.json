    {
      "name": "Bookings - My Active",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('My active booking returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('My active booking exists', function () {",
              "  pm.expect(json).to.have.property('booking');",
              "  pm.expect(json.booking).to.not.eql(null);",
              "});",
              "pm.test('My active booking id matches flow booking id', function () {",
              "  pm.expect(json.booking.id).to.eql(pm.collectionVariables.get('booking_id'));",
              "});"
            ]
          }
        }
