    {
      "name": "Scan - Intake",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Intake returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('booking_id', json.booking.booking_id);",
              "pm.test('Intake status dropped_off', function () {",
              "  pm.expect(json.booking.status).to.eql('dropped_off');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{staff_access_token}}" },
          { "key": "Content-Type", "value": "application/json" }
