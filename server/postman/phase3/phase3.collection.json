    {
      "name": "Auth - Student Signup",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const seed = Date.now().toString();",
              "pm.collectionVariables.set('student_name', 'Student ' + seed.slice(-4));",
              "pm.collectionVariables.set('student_reg_no', '24BCE' + seed.slice(-6));",
              "pm.collectionVariables.set('student_email', 'student.' + seed + '@vitstudent.ac.in');",
              "if (!pm.collectionVariables.get('student_password')) {",
              "  pm.collectionVariables.set('student_password', '123456');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Student signup returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{student_name}}\",\n  \"reg_no\": \"{{student_reg_no}}\",\n  \"email\": \"{{student_email}}\",\n  \"password\": \"{{student_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/student/signup",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "student", "signup"]
        }
      }
    },
    {
      "name": "Auth - Student Signin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Student signin returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('student_access_token', json.access_token);",
              "pm.collectionVariables.set('student_refresh_token', json.refresh_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{student_email}}\",\n  \"password\": \"{{student_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/student/signin",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "student", "signin"]
        }
      }
    },
    {
      "name": "Student - Init Bag",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Init bag returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Init bag returns qr_payload', function () {",
              "  pm.expect(json).to.have.property('qr_payload');",
              "});",
              "pm.collectionVariables.set('qr_payload', json.qr_payload);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{student_access_token}}" }
