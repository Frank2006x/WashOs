    {
      "name": "Notifications - My Unread",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{student_access_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/notifications/my/unread?limit=20&offset=0",
          "host": ["{{baseUrl}}"],
          "path": ["api", "notifications", "my", "unread"],
          "query": [
            { "key": "limit", "value": "20" },
            { "key": "offset", "value": "0" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Unread notifications returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Unread notifications returns array', function () {",
              "  pm.expect(Array.isArray(json.notifications)).to.eql(true);",
              "});",
              "if (json.notifications.length > 0) {",
              "  pm.collectionVariables.set('notification_id', json.notifications[0].id);",
              "} else {",
              "  pm.collectionVariables.set('notification_id', '00000000-0000-0000-0000-000000000000');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Notifications - Mark Read",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{student_access_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/notifications/{{notification_id}}/read",
          "host": ["{{baseUrl}}"],
          "path": ["api", "notifications", "{{notification_id}}", "read"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Mark read returns 200 when unread exists, else 404', function () {",
              "  pm.expect([200, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
