    {
      "name": "Scan - Pickup Verify (Expected Conflict Until Ready)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{student_access_token}}"
          },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"qr_code\": \"{{qr_payload}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/scan/pickup-verify",
          "host": ["{{baseUrl}}"],
          "path": ["api", "scan", "pickup-verify"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Pickup verify returns 409 before ready_for_pickup', function () {",
              "  pm.response.to.have.status(409);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Bookings - Collect (Expected Conflict Until Ready)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{student_access_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/bookings/{{booking_id}}/collect",
          "host": ["{{baseUrl}}"],
          "path": ["api", "bookings", "{{booking_id}}", "collect"]
