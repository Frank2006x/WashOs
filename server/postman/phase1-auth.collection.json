  "item": [
    {
      "name": "Health - Ping",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ping",
          "host": ["{{baseUrl}}"],
          "path": ["ping"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ping returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Student Signup",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const seed = Date.now().toString();",
              "pm.collectionVariables.set('student_name', 'Student ' + seed.slice(-4));",
              "pm.collectionVariables.set('student_reg_no', '24BCE' + seed.slice(-6));",
              "pm.collectionVariables.set('student_email', 'student.' + seed + '@vitstudent.ac.in');",
              "if (!pm.collectionVariables.get('student_password')) {",
              "  pm.collectionVariables.set('student_password', '123456');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Student signup returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Student user payload exists', function () {",
              "  pm.expect(json).to.have.property('user');",
              "  pm.expect(json.user).to.have.property('email');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{student_name}}\",\n  \"reg_no\": \"{{student_reg_no}}\",\n  \"email\": \"{{student_email}}\",\n  \"password\": \"{{student_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/student/signup",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "student", "signup"]
        }
      }
    },
    {
      "name": "Auth - Student Signin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Student signin returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Student signin returns tokens', function () {",
              "  pm.expect(json).to.have.property('access_token');",
              "  pm.expect(json).to.have.property('refresh_token');",
              "});",
              "if (json.access_token) pm.collectionVariables.set('access_token', json.access_token);",
              "if (json.refresh_token) pm.collectionVariables.set('refresh_token', json.refresh_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{student_email}}\",\n  \"password\": \"{{student_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/student/signin",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "student", "signin"]
        }
      }
    },
