  "item": [
    {
      "name": "Health - Ping",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ping",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "ping"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Ping returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Ping body is pong', function () {",
              "  pm.expect(pm.response.text()).to.eql('pong');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Login returns token pair', function () {",
              "  pm.expect(json).to.have.property('access_token');",
              "  pm.expect(json).to.have.property('refresh_token');",
              "});",
              "const nextAccessToken = json.access_token || json.token;",
              "const nextRefreshToken = json.refresh_token;",
              "if (typeof nextAccessToken === 'string' && nextAccessToken.length > 0) {",
              "  pm.collectionVariables.set('access_token', nextAccessToken);",
              "}",
              "if (typeof nextRefreshToken === 'string' && nextRefreshToken.length > 0) {",
              "  pm.collectionVariables.set('refresh_token', nextRefreshToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "refresh"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Refresh returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Refresh returns rotated token pair', function () {",
              "  pm.expect(json).to.have.property('access_token');",
              "  pm.expect(json).to.have.property('refresh_token');",
              "});",
              "const nextAccessToken = json.access_token || json.token;",
              "const nextRefreshToken = json.refresh_token;",
              "if (typeof nextAccessToken === 'string' && nextAccessToken.length > 0) {",
              "  pm.collectionVariables.set('access_token', nextAccessToken);",
              "}",
              "if (typeof nextRefreshToken === 'string' && nextRefreshToken.length > 0) {",
              "  pm.collectionVariables.set('refresh_token', nextRefreshToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
