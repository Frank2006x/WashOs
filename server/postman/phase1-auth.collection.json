    {
      "name": "Auth - Staff Signup",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const seed = Date.now().toString();",
              "pm.collectionVariables.set('staff_name', 'Staff ' + seed.slice(-4));",
              "pm.collectionVariables.set('staff_phone', '+9199' + seed.slice(-8));",
              "pm.collectionVariables.set('staff_email', 'staff.' + seed + '@washos.local');",
              "if (!pm.collectionVariables.get('staff_password')) {",
              "  pm.collectionVariables.set('staff_password', '123456');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Staff signup route is reachable', function () {",
              "  pm.expect([201, 412]).to.include(pm.response.code);",
              "});",
              "pm.collectionVariables.set('staff_signup_status', String(pm.response.code));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{staff_name}}\",\n  \"phone\": \"{{staff_phone}}\",\n  \"email\": \"{{staff_email}}\",\n  \"password\": \"{{staff_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/staff/signup",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "staff", "signup"]
        }
      }
    },
    {
      "name": "Auth - Staff Signin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const signupStatus = pm.collectionVariables.get('staff_signup_status');",
              "if (signupStatus === '201') {",
              "  pm.test('Staff signin returns 200 when staff exists', function () {",
              "    pm.response.to.have.status(200);",
              "  });",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('access_token');",
              "  pm.expect(json).to.have.property('refresh_token');",
              "  pm.collectionVariables.set('staff_access_token', json.access_token);",
              "  pm.collectionVariables.set('staff_refresh_token', json.refresh_token);",
              "} else {",
              "  pm.test('Staff signin returns 401 when service is missing', function () {",
              "    pm.response.to.have.status(401);",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{staff_phone}}\",\n  \"password\": \"{{staff_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/staff/signin",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "staff", "signin"]
        }
      }
    },
