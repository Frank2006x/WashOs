    {
      "name": "Auth - Student Signup",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const seed = Date.now().toString();",
              "pm.collectionVariables.set('student_name', 'Student ' + seed.slice(-4));",
              "pm.collectionVariables.set('student_reg_no', '24BCE' + seed.slice(-6));",
              "pm.collectionVariables.set('student_email', 'student.query.' + seed + '@vitstudent.ac.in');",
              "if (!pm.collectionVariables.get('student_password')) {",
              "  pm.collectionVariables.set('student_password', '123456');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Student signup returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{student_name}}\",\n  \"reg_no\": \"{{student_reg_no}}\",\n  \"email\": \"{{student_email}}\",\n  \"password\": \"{{student_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/student/signup",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "student", "signup"]
        }
      }
    },
