            "value": "Bearer {{student_access_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/notifications/my?limit=20&offset=0",
          "host": ["{{baseUrl}}"],
          "path": ["api", "notifications", "my"],
          "query": [
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Notifications list returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "const notifications = Array.isArray(json.notifications) ? json.notifications : [];",
              "pm.test('Notifications array exists', function () {",
              "  pm.expect(Array.isArray(json.notifications)).to.eql(true);",
              "});",
              "const bookingId = pm.collectionVariables.get('booking_id');",
              "const readyNotification = notifications.find(function (n) {",
              "  const payload = n && n.payload && typeof n.payload === 'object' ? n.payload : {};",
              "  return payload.booking_id === bookingId && n.title === 'Laundry Ready for Pickup';",
              "});",
              "pm.test('Ready notification exists for booking', function () {",
              "  pm.expect(!!readyNotification).to.eql(true);",
              "});",
              "pm.test('Ready notification payload includes row_no', function () {",
              "  const payload = readyNotification && readyNotification.payload && typeof readyNotification.payload === 'object' ? readyNotification.payload : {};",
              "  pm.expect(payload.row_no).to.eql(pm.collectionVariables.get('row_no'));",
              "});"
            ]
          }
        }
      ]
    },
