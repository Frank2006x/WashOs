    {
      "name": "Booking - Events (Student View)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{student_access_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/bookings/{{booking_id}}/events",
          "host": ["{{baseUrl}}"],
          "path": ["api", "bookings", "{{booking_id}}", "events"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Booking events returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "const bookingId = pm.collectionVariables.get('booking_id') || '';",
              "const events = Array.isArray(json.events) ? json.events : [];",
              "pm.collectionVariables.set('last_events_count', String(events.length));",
              "pm.test('booking_id variable is set', function () {",
              "  pm.expect(bookingId).to.not.eql('');",
              "});",
              "pm.test('Events array exists', function () {",
              "  pm.expect(Array.isArray(json.events)).to.eql(true);",
              "});",
              "pm.test('Events are not empty', function () {",
              "  if (events.length === 0) {",
              "    pm.expect.fail('No workflow events for booking_id=' + bookingId + '. Run the collection from the top and confirm scan steps succeeded for this same booking.');",
              "  }",
              "});",
              "function parseMetadata(metadata) {",
              "  if (!metadata) return {};",
              "",
              "  function decodeBase64ToUtf8(input) {",
              "    if (typeof input !== 'string' || input.length === 0) return '';",
              "    try {",
              "      if (typeof atob === 'function') {",
              "        return decodeURIComponent(escape(atob(input)));",
              "      }",
              "    } catch (e) {}",
              "    try {",
              "      if (typeof Buffer !== 'undefined' && Buffer.from) {",
              "        return Buffer.from(input, 'base64').toString('utf8');",
              "      }",
              "    } catch (e) {}",
              "    return '';",
              "  }",
              "",
              "  if (typeof metadata === 'object') {",
              "    if (metadata.machine_code || metadata.row_no || metadata.machineCode || metadata.rowNo) {",
              "      return metadata;",
              "    }",
              "",
              "    if (typeof metadata.string === 'string') {",
              "      try { return JSON.parse(metadata.string); } catch (e) {}",
              "    }",
              "",
              "    if (typeof metadata.data === 'string') {",
              "      try { return JSON.parse(metadata.data); } catch (e) {}",
              "      try {",
              "        const decoded = decodeBase64ToUtf8(metadata.data);",
              "        if (decoded) return JSON.parse(decoded);",
              "      } catch (e) {}",
              "    }",
              "",
              "    if (metadata.type === 'Buffer' && Array.isArray(metadata.data)) {",
              "      try {",
              "        const raw = String.fromCharCode.apply(null, metadata.data);",
              "        return JSON.parse(raw);",
              "      } catch (e) {}",
              "    }",
              "",
              "    if (Array.isArray(metadata.bytes)) {",
              "      try {",
              "        const decoded = String.fromCharCode.apply(null, metadata.bytes);",
              "        return JSON.parse(decoded);",
              "      } catch (e) {}",
              "    }",
              "",
              "    return metadata;",
              "  }",
              "",
              "  if (typeof metadata !== 'string') return {};",
              "",
              "  try { return JSON.parse(metadata); } catch (e) {}",
              "  try {",
              "    const decoded = decodeBase64ToUtf8(metadata);",
              "    if (decoded) return JSON.parse(decoded);",
              "  } catch (e) {}",
              "",
              "  return {};",
              "}",
              "const normalized = events.map(function (e) {",
              "  return {",
              "    event_type: e.event_type,",
              "    metadata: parseMetadata(e.metadata)",
              "  };",
              "});",
              "const types = normalized.map(function (e) { return e.event_type; });",
              "const requiredTypes = ['received', 'wash_started', 'wash_finished', 'dry_started', 'dry_finished', 'marked_ready', 'collected'];",
              "const missingTypes = requiredTypes.filter(function (t) { return types.indexOf(t) === -1; });",
              "pm.test('Required lifecycle event types exist', function () {",
              "  if (missingTypes.length > 0) {",
              "    pm.expect.fail('Missing event types: ' + missingTypes.join(', ') + ' | Found: ' + types.join(', '));",
              "  }",
              "});",
              "const hasMachineCode = normalized.some(function (e) {",
              "  return !!(",
              "    (e.metadata && (e.metadata.machine_code || e.metadata.machineCode)) ||",
              "    e.machine_code ||",
              "    e.machineCode",
              "  );",
              "});",
              "const hasRowNo = normalized.some(function (e) {",
              "  return !!(",
              "    (e.metadata && (e.metadata.row_no || e.metadata.rowNo)) ||",
              "    e.row_no ||",
              "    e.rowNo",
              "  );",
              "});",
              "pm.test('Events include machine_code metadata', function () {",
              "  pm.expect(hasMachineCode).to.eql(true);",
              "});",
              "pm.test('Events include row_no metadata', function () {",
              "  pm.expect(hasRowNo).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    }
