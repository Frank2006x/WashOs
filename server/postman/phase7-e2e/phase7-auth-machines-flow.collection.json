    {
      "name": "Auth - Student Signup",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const seed = Date.now().toString();",
              "pm.collectionVariables.set('student_name', 'Phase7 Student ' + seed.slice(-4));",
              "pm.collectionVariables.set('student_reg_no', '24BCE' + seed.slice(-6));",
              "pm.collectionVariables.set('student_email', 'phase7.student.' + seed + '@washos.com');",
              "if (!pm.collectionVariables.get('student_password')) {",
              "  pm.collectionVariables.set('student_password', 'password123');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Student signup returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Student signup response includes user', function () {",
              "  pm.expect(json).to.have.property('user');",
              "  pm.expect(json.user).to.have.property('email');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{student_name}}\",\n  \"reg_no\": \"{{student_reg_no}}\",\n  \"email\": \"{{student_email}}\",\n  \"password\": \"{{student_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/student/signup",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "student", "signup"]
        }
