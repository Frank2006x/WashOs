    {
      "name": "Machines - List Washers",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{staff_access_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/machines?type=washer",
          "host": ["{{baseUrl}}"],
          "path": ["api", "machines"],
          "query": [
            {
              "key": "type",
              "value": "washer"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('List washers returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Washers array exists', function () {",
              "  pm.expect(Array.isArray(json.machines)).to.eql(true);",
              "  pm.expect(json.machines.length).to.be.greaterThan(0);",
              "});",
              "const washer = (json.machines || []).find(function (m) { return m.is_active !== false; }) || json.machines[0];",
              "pm.collectionVariables.set('washer_machine_id', washer ? washer.id : '');",
              "pm.collectionVariables.set('washer_machine_code', washer ? washer.code : '');"
            ]
          }
        }
      ]
    },
