    {
      "name": "Student - Available Slots (Today)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const existing = pm.collectionVariables.get('slot_date');",
              "const envDate = pm.environment.get('slot_date');",
              "const validDate = (v) => /^\\d{4}-\\d{2}-\\d{2}$/.test(v || '');",
              "if (validDate(existing)) {",
              "  pm.environment.set('slot_date', existing);",
              "} else if (validDate(envDate)) {",
              "  pm.collectionVariables.set('slot_date', envDate);",
              "} else {",
              "  const now = new Date();",
              "  const ist = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Kolkata' }));",
              "  const yyyy = ist.getFullYear();",
              "  const mm = String(ist.getMonth() + 1).padStart(2, '0');",
              "  const dd = String(ist.getDate()).padStart(2, '0');",
              "  const computedDate = `${yyyy}-${mm}-${dd}`;",
              "  pm.collectionVariables.set('slot_date', computedDate);",
              "  pm.environment.set('slot_date', computedDate);",
              "}",
              "const rawFloor = pm.collectionVariables.get('student_floor_no') || pm.environment.get('student_floor_no') || '1';",
              "const parsedFloor = Number(rawFloor);",
              "const normalizedFloor = Number.isFinite(parsedFloor) && parsedFloor >= 1 && parsedFloor <= 8 ? String(Math.trunc(parsedFloor)) : '1';",
              "pm.collectionVariables.set('student_floor_no', normalizedFloor);",
              "pm.environment.set('student_floor_no', normalizedFloor);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{student_access_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/student/me/slots/available?date={{slot_date}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "student", "me", "slots", "available"],
          "query": [{ "key": "date", "value": "{{slot_date}}" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 409) {",
              "  const bodyText = pm.response.text();",
              "  pm.test('Slots schema configured', function () {",
              "    pm.expect(bodyText).to.not.include('slot schedule is not configured');",
              "  });",
              "  if (bodyText.includes('slot schedule is not configured')) {",
              "    pm.expect.fail('DB schema missing: apply server/sql/schema.sql and server/sql/seed.sql before Phase8 tests.');",
              "  }",
              "}",
              "pm.test('Available slots returns 200', function () { pm.response.to.have.status(200); });",
              "let json = {};",
              "try { json = pm.response.json(); } catch (e) {",
              "  pm.expect.fail('Available slots response is not JSON');",
              "}",
              "const slots = Array.isArray(json.slots) ? json.slots : [];",
              "const resolvedDate = pm.collectionVariables.get('slot_date') || pm.environment.get('slot_date') || (typeof json.date === 'string' ? json.date.slice(0, 10) : '');",
              "if (resolvedDate) {",
              "  pm.collectionVariables.set('slot_date', resolvedDate);",
              "  pm.environment.set('slot_date', resolvedDate);",
              "}",
              "pm.test('Slots array exists', function () {",
              "  pm.expect(Array.isArray(json.slots)).to.eql(true);",
              "});",
              "if (!slots.length) {",
              "  const dateVal = pm.collectionVariables.get('slot_date') || pm.environment.get('slot_date') || 'unresolved';",
              "  const floorVal = pm.collectionVariables.get('student_floor_no') || pm.environment.get('student_floor_no') || 'unresolved';",
              "  const bodyText = pm.response.text();",
              "  pm.expect.fail(`No eligible slots for date ${dateVal} and floor ${floorVal}. Response: ${bodyText}`);",
              "} else {",
              "  pm.test('At least one eligible slot exists', function () {",
              "    pm.expect(slots.length).to.be.greaterThan(0);",
              "  });",
              "  const now = new Date();",
              "  let selected = slots.find((s) => {",
              "    const start = s.start_at ? new Date(s.start_at) : null;",
              "    const end = s.end_at ? new Date(s.end_at) : null;",
              "    return start && end && now >= start && now < end;",
              "  });",
              "  if (!selected) {",
              "    selected = slots.find((s) => {",
              "      const end = s.end_at ? new Date(s.end_at) : null;",
              "      return end && now < end;",
              "    });",
              "  }",
              "  if (!selected) { selected = slots[0] || {}; }",
              "  pm.collectionVariables.set('slot_window_id', selected.slot_window_id || selected.id || '');",
              "  pm.collectionVariables.set('base_start_floor', String(selected.allowed_start_floor || 1));",
              "  pm.collectionVariables.set('base_end_floor', String(selected.allowed_end_floor || 2));",
              "  const nextStart = Number(selected.allowed_end_floor || 2) + 1;",
              "  const nextEnd = nextStart;",
              "  pm.collectionVariables.set('next_start_floor', String(nextStart));",
              "  pm.collectionVariables.set('next_end_floor', String(nextEnd));",
              "  pm.collectionVariables.set('override_enabled_until', pm.collectionVariables.get('slot_date') + 'T23:59:59+05:30');",
              "  pm.collectionVariables.set('selected_slot_start_at', selected.start_at || '');",
              "  pm.collectionVariables.set('selected_slot_end_at', selected.end_at || '');",
              "}"
            ]
          }
        }
      ]
    },
